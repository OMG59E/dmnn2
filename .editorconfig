# ==============================================================================
# dmnn2 EditorConfig Configuration
# ==============================================================================
# https://editorconfig.org

root = true

# ------------------------------------------------------------------------------
# Default Settings
# ------------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ------------------------------------------------------------------------------
# C/C++ Source Files
# ------------------------------------------------------------------------------
[*.{c,cpp,cc,cxx,cu,cuh,h,hpp,hxx}]
indent_style = space
indent_size = 4

# ------------------------------------------------------------------------------
# CMake Files
# ------------------------------------------------------------------------------
[{CMakeLists.txt,*.cmake}]
indent_style = space
indent_size = 4

# ------------------------------------------------------------------------------
# Python Files
# ------------------------------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4

# ------------------------------------------------------------------------------
# YAML Files
# ------------------------------------------------------------------------------
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# ------------------------------------------------------------------------------
# JSON Files
# ------------------------------------------------------------------------------
[*.json]
indent_style = space
indent_size = 2

# ------------------------------------------------------------------------------
# Markdown Files
# ------------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false

# ------------------------------------------------------------------------------
# Makefile
# ------------------------------------------------------------------------------
[Makefile]
indent_style = tab

# ------------------------------------------------------------------------------
# Shell Scripts
# ------------------------------------------------------------------------------
[*.sh]
indent_style = space
indent_size = 2